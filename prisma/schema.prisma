// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// TODO: seperate the overtime hours and basic hours also add a department section

model TimeEntry {
  id          Int      @id @default(autoincrement())
  clerkId     String // Store Clerk's unique user ID here
  hoursWorked Float // Number of hours worked
  hourlyRate  Float // User's hourly rate for this entry
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
